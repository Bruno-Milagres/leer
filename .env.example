# ──────────────────────────────────────────────
# Leer — Configuração de ambiente
# Copie para .env e ajuste conforme seu ambiente
# ──────────────────────────────────────────────

# Calibre-Web — backend OPDS
# Para dev local (emulador Android): use 10.0.2.2
# Para celular físico na mesma rede: use o IP da máquina (ex: 192.168.1.100)
# Para servidor remoto (Oracle etc.): use o IP/domínio do servidor
CALIBRE_WEB_HOST=localhost
CALIBRE_WEB_PORT=8083
CALIBRE_WEB_USERNAME=admin
CALIBRE_WEB_PASSWORD=admin123

# Timezone do container Docker
TZ=America/Sao_Paulo
